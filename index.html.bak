<style>
        .glass-card {
            background: rgba(17, 24, 39, 0.8);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(59, 130, 246, 0.2);
            transition: all 0.3s ease;
        }
        .glass-card:hover {
            border-color: rgba(59, 130, 246, 0.5);
            transform: translateY(-4px);
        }
        .gradient-card {
            background: #0f172a;
            border: 1px solid rgba(59, 130, 246, 0.1);
            position: relative;
            transition: all 0.3s ease;
        }
        .gradient-card:hover {
            border-color: rgba(59, 130, 246, 0.4);
        }
        /* Gradient Border for sections matching reference images */
        .gradient-border-card {
            position: relative;
            background: #0f172a;
            border-radius: 0.75rem;
            z-index: 1;
            transition: all 0.3s ease;
        }
        .gradient-border-card::before {
            content: "";
            position: absolute;
            inset: -1px;
            border-radius: 0.75rem;
            padding: 1px;
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.5) 0%, rgba(244, 63, 94, 0.3) 100%);
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            pointer-events: none;
            z-index: -1;
        }
        .gradient-border-card:hover {
            transform: translateY(-4px);
        }
        .gradient-border-card:hover::before {
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.8) 0%, rgba(244, 63, 94, 0.6) 100%);
        }

        .gradient-text {
            background: linear-gradient(135deg, #3b82f6 0%, #f43f5e 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .bg-glow {
            position: absolute;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, rgba(11, 17, 33, 0) 70%);
            z-index: -1;
            filter: blur(60px);
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .skill-icon-container {
            width: 80px;
            height: 80px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
        }
    
        @keyframes spin-slow {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        .animate-spin-slow {
            animation: spin-slow 25s linear infinite;
        }
        #home {
            background: radial-gradient(circle at 80% 20%, rgba(59, 130, 246, 0.1) 0%, transparent 40%),
                        radial-gradient(circle at 20% 80%, rgba(244, 63, 94, 0.05) 0%, transparent 40%);
        }
        .btn-primary {
            background: linear-gradient(135deg, #3b82f6 0%, #f43f5e 100%);
            transition: all 0.3s ease;
        }
        .btn-primary:hover {
            opacity: 0.9;
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(59, 130, 246, 0.4);
        }
        .btn-outline {
            border: 1px solid rgba(59, 130, 246, 0.5);
            transition: all 0.3s ease;
        }
        .btn-outline:hover {
            background: rgba(59, 130, 246, 0.1);
            border-color: #3b82f6;
        }
    </style>
<style>
